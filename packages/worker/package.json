{
  "name": "@survibe/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "WRANGLER_WRITE_LOGS=false wrangler dev",
    "build": "WRANGLER_WRITE_LOGS=false wrangler deploy --dry-run --outdir dist",
    "deploy": "WRANGLER_WRITE_LOGS=false wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:create": "WRANGLER_WRITE_LOGS=false wrangler d1 create survibe",
    "db:migrate:local": "WRANGLER_WRITE_LOGS=false wrangler d1 migrations apply survibe --local",
    "db:migrate:remote": "WRANGLER_WRITE_LOGS=false wrangler d1 migrations apply survibe --remote",
    "cf:secret:openai": "WRANGLER_WRITE_LOGS=false wrangler secret put OPENAI_API_KEY"
  },
  "dependencies": {
    "@survibe/shared": "0.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.0.0"
  }
}
